# Feishu app credentials.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_ENCRYPT_KEY=

# Optional but recommended when the app receives more than direct bot mentions.
# You can set either one. The bot also responds in p2p chats.
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_NAME=

# Feishu Open Platform domain. Use https://open.feishu.cn for Feishu China,
# or https://open.larksuite.com for Lark global tenants.
FEISHU_DOMAIN=https://open.feishu.cn

# Feishu message reaction emoji_type values. Set to "off" to disable.
FEISHU_PROCESSING_REACTION_EMOJI=Typing
FEISHU_DONE_REACTION_EMOJI=DONE

# Optional: group custom bot webhook used by the local card sender UI at /cards.
CARD_SENDER_WEBHOOK=
# Optional: send /cards via the Feishu app bot to this chat_id instead of webhook.
CARD_SENDER_CHAT_ID=

# HTTP callback server.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8000
BRIDGE_WORKERS=2
BRIDGE_STATE_PATH=.feishu-opencode-bridge/state.json

# Context and reply limits.
BRIDGE_CONTEXT_MAX_MESSAGES=80
BRIDGE_REPLY_MAX_CHARS=3800
BRIDGE_HISTORY_PAGE_LIMIT=5
BRIDGE_MODEL_LIST_MAX_CHARS=8000
BRIDGE_SEND_PROCESSING_MESSAGE=false

# OpenCode runtime.
OPENCODE_BIN=opencode
OPENCODE_DEFAULT_MODEL=
OPENCODE_WORKDIR=.
OPENCODE_TIMEOUT_SECONDS=900
OPENCODE_AGENT=
OPENCODE_ATTACH_URL=
OPENCODE_SKIP_PERMISSIONS=false
OPENCODE_REPLY_FULL_OUTPUT=false
